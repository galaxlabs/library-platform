# Django
DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,library.digigalaxy.cloud
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://library.digigalaxy.cloud
CSRF_TRUSTED_ORIGINS=https://library.digigalaxy.cloud
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
LOG_LEVEL=INFO

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=library_db
DB_USER=library_user
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/1

# AI Providers
ENCRYPTION_KEY=change-me-to-a-generated-fernet-key

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXP_DELTA_SECONDS=900

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# API Keys (encrypted in database, not here)
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=https://library.digigalaxy.cloud/api/v1
